# Site Configuration
NEXT_PUBLIC_SITE_URL=https://drpedrofelipe.com.br

# Força dados locais (true = não consulta Supabase nas páginas públicas)
# USE_LOCAL_DATA=true

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

# Aliases opcionais (se usar @supabase/server)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
SUPABASE_SECRET_KEY=your-secret-key-here

# Vercel Blob (para upload de imagens)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxx

# Google Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Email Service (optional - for contact form)
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Google Maps API (optional - for location map)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaxxxxxxxxxx
